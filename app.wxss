/**app.wxss**/
page {
  background-color: #F7F7F7;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #191919;
  line-height: 1.5;
}

/* 主题色 */
.theme-primary {
  color: #07C160;
}

.bg-primary {
  background-color: #07C160;
}

/* 通用容器 */
.container {
  padding: 32rpx;
}

/* 卡片样式 */
.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 按钮样式 */
.btn-primary {
  background-color: #07C160;
  color: #ffffff;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.btn-primary:active {
  background-color: #06AD56;
}

.btn-secondary {
  background-color: #ffffff;
  color: #07C160;
  border: 2rpx solid #07C160;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
}

.btn-disabled {
  background-color: #CCCCCC;
  color: #ffffff;
}

/* 文本样式 */
.text-primary {
  color: #191919;
}

.text-secondary {
  color: #666666;
}

.text-hint {
  color: #999999;
  font-size: 24rpx;
}

.text-success {
  color: #07C160;
}

.text-danger {
  color: #FA5151;
}

/* 间距工具类 */
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }

/* Flex布局 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: #E5E5E5;
  margin: 24rpx 0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
  color: #999999;
}

.empty-state-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-state-text {
  font-size: 28rpx;
  color: #999999;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 48rpx;
  color: #999999;
}

/* 头像 */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160, #576B95);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-weight: 600;
  font-size: 32rpx;
}

.avatar-small {
  width: 64rpx;
  height: 64rpx;
  font-size: 24rpx;
}

.avatar-large {
  width: 120rpx;
  height: 120rpx;
  font-size: 48rpx;
}
