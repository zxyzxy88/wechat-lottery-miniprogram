/* pages/history/history.wxss */
.page-container {
  min-height: 100vh;
  background-color: #F7F7F7;
}

/* 页面头部 */
.page-header {
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  color: #ffffff;
}

.header-title {
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 历史列表 */
.history-list {
  padding: 32rpx;
}

.history-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.history-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
}

.history-count {
  font-size: 24rpx;
  color: #999999;
}

.history-prizes {
  margin-bottom: 24rpx;
}

.prize-summary {
  font-size: 26rpx;
  color: #666666;
}

.prize-list {
  color: #07C160;
  font-weight: 500;
}

.history-winners {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.winner-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #F0F9F4;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.winner-prize {
  color: #07C160;
  font-weight: 600;
}

.winner-name {
  color: #666666;
}

.history-actions {
  display: flex;
  gap: 24rpx;
  justify-content: flex-end;
}

.btn-detail,
.btn-delete {
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
}

.btn-detail {
  color: #07C160;
  background: #F0F9F4;
}

.btn-delete {
  color: #FA5151;
  background: #FFF0F0;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 200rpx 48rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
}

.modal-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-container.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
  flex-shrink: 0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 32rpx;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #F0F0F0;
  background: #ffffff;
  flex-shrink: 0;
}

.btn-share,
.btn-close-modal {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  line-height: 88rpx;
}

.btn-share {
  background: #07C160;
  color: #ffffff;
}

.btn-close-modal {
  background: #F7F7F7;
  color: #666666;
}

/* 详情内容 */
.detail-section {
  margin-bottom: 32rpx;
}

.detail-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.detail-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #191919;
}

.prizes-detail {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.prize-detail-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background: #F7F7F7;
  border-radius: 8rpx;
}

.prize-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
}

.prize-badge.first {
  background: linear-gradient(135deg, #FFD700, #FFA500);
}

.prize-badge.second {
  background: linear-gradient(135deg, #C0C0C0, #A8A8A8);
}

.prize-badge.third {
  background: linear-gradient(135deg, #CD7F32, #B87333);
}

.prize-badge.other {
  background: #E5E5E5;
  color: #666666;
}

.prize-count {
  font-size: 26rpx;
  color: #666666;
}

.winners-detail {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.winner-detail-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #F7F7F7;
  border-radius: 8rpx;
}

.winner-detail-item .winner-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160, #576B95);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-weight: 600;
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.winner-detail-item .winner-info {
  flex: 1;
}

.winner-detail-item .winner-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.winner-detail-item .winner-prize {
  font-size: 24rpx;
  color: #07C160;
}
