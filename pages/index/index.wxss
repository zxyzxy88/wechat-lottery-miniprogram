/* pages/index/index.wxss */
.page-container {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background-color: #F7F7F7;
}

/* 页面头部 */
.page-header {
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  color: #ffffff;
}

.header-title {
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 数据来源选择 */
.source-section {
  padding: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  color: #191919;
}

.source-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
}

.source-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.source-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.group-icon {
  background: linear-gradient(135deg, #576B95, #476B9A);
}

.friend-icon {
  background: linear-gradient(135deg, #07C160, #06AD56);
}

.manual-icon {
  background: linear-gradient(135deg, #FA9D3B, #F09438);
}

.source-info {
  flex: 1;
}

.source-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #191919;
  margin-bottom: 8rpx;
}

.source-desc {
  font-size: 24rpx;
  color: #999999;
}

.source-arrow {
  font-size: 48rpx;
  color: #CCCCCC;
}

/* 已选择参与者 */
.selected-section {
  margin: 0 32rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.participant-count {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 600;
}

.participants-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.participant-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: calc(25% - 12rpx);
  margin-bottom: 16rpx;
}

.participant-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160, #576B95);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.participant-name {
  font-size: 24rpx;
  color: #666666;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.participant-remove {
  position: absolute;
  top: -8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: #FA5151;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
}

.section-actions {
  margin-top: 16rpx;
  text-align: right;
}

.btn-text-danger {
  display: inline-block;
  color: #FA5151;
  font-size: 28rpx;
  padding: 8rpx 16rpx;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
}

.empty-state-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-state-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.empty-state-hint {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #ffffff;
  padding: 24rpx 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: space-between;
  z-index: 100;
}

.selected-info {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666666;
}

.info-count {
  font-size: 48rpx;
  font-weight: 700;
  color: #07C160;
}

.btn-next {
  background: #07C160;
  color: #ffffff;
  border: none;
  border-radius: 48rpx;
  padding: 24rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1;
}

.btn-next:active {
  background: #06AD56;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
}

.modal-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 0.3s;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-container.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
  flex-shrink: 0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
}

.modal-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #F0F0F0;
  background: #ffffff;
  flex-shrink: 0;
}

/* 群聊列表 */
.group-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.group-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F7F7F7;
  border-radius: 16rpx;
}

.group-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #576B95, #476B9A);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-weight: 600;
  font-size: 32rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.group-info {
  flex: 1;
}

.group-name {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.group-count {
  font-size: 24rpx;
  color: #999999;
}

.select-type {
  display: flex;
  gap: 12rpx;
}

.btn-select-all,
.btn-select-partial {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
  border-radius: 8rpx;
  border: none;
  line-height: 1;
}

.btn-select-all {
  background: #07C160;
  color: #ffffff;
}

.btn-select-partial {
  background: #ffffff;
  color: #07C160;
  border: 1rpx solid #07C160;
}

/* 成员列表 */
.modal-search {
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.search-input {
  width: 100%;
  height: 72rpx;
  background: #F7F7F7;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
}

.modal-actions {
  display: flex;
  gap: 32rpx;
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.btn-text {
  font-size: 28rpx;
  color: #07C160;
}

.member-list {
  display: flex;
  flex-direction: column;
}

.member-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
}

.member-item.selected {
  background: #F0F9F4;
  margin: 0 -32rpx;
  padding: 24rpx 32rpx;
}

.member-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #CCCCCC;
  border-radius: 8rpx;
  margin-right: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.member-item.selected .member-checkbox {
  background: #07C160;
  border-color: #07C160;
}

.checkbox-inner {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160, #576B95);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-weight: 600;
  font-size: 28rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.member-info {
  flex: 1;
}

.member-name {
  font-size: 30rpx;
}

.selected-count {
  font-size: 28rpx;
  color: #666666;
}

.btn-cancel,
.btn-confirm {
  padding: 20rpx 48rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  border: none;
  line-height: 1;
}

.btn-cancel {
  background: #F7F7F7;
  color: #666666;
}

.btn-confirm {
  background: #07C160;
  color: #ffffff;
}

/* 手动输入 */
.manual-textarea {
  width: 100%;
  min-height: 400rpx;
  padding: 24rpx;
  background: #F7F7F7;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.8;
}

.input-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
}
