/* pages/lottery/lottery.wxss */
.page-container {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background-color: #F7F7F7;
}

/* 页面头部 */
.page-header {
  padding: 48rpx 32rpx 32rpx;
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  color: #ffffff;
}

.header-title {
  font-size: 48rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}

/* 奖项设置 */
.prizes-section {
  margin: 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
}

.btn-add {
  font-size: 28rpx;
  color: #07C160;
  font-weight: 500;
}

.prizes-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.prize-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #F7F7F7;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.prize-item:active {
  border-color: #07C160;
}

.prize-rank {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 700;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.prize-rank.first {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #ffffff;
}

.prize-rank.second {
  background: linear-gradient(135deg, #C0C0C0, #A8A8A8);
  color: #ffffff;
}

.prize-rank.third {
  background: linear-gradient(135deg, #CD7F32, #B87333);
  color: #ffffff;
}

.prize-rank.other {
  background: #E5E5E5;
  color: #666666;
}

.prize-inputs {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.prize-name-input {
  width: 100%;
  height: 64rpx;
  padding: 0 16rpx;
  background: #ffffff;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.prize-count-input {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.count-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 8rpx;
  background: #07C160;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
}

.count-btn:active {
  background: #06AD56;
}

.count-value {
  flex: 1;
  height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #07C160;
}

.btn-remove {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #FA5151;
  margin-left: 16rpx;
}

.empty-prizes {
  text-align: center;
  padding: 48rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 抽奖区域 */
.lottery-section {
  margin: 0 32rpx 32rpx;
}

.lottery-box {
  background: linear-gradient(135deg, #07C160, #576B95);
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.3);
}

.lottery-info {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.info-item {
  text-align: center;
}

.info-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
}

.info-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

.lottery-display {
  background: #ffffff;
  border-radius: 16rpx;
  min-height: 240rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.placeholder {
  text-align: center;
  color: #CCCCCC;
}

.placeholder-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
  opacity: 0.5;
}

.placeholder-text {
  font-size: 28rpx;
}

.rolling-name {
  font-size: 64rpx;
  font-weight: 700;
  color: #191919;
  animation: roll 0.15s linear infinite;
}

@keyframes roll {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.winner-display {
  text-align: center;
  animation: reveal 0.5s ease;
}

@keyframes reveal {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.congratulations {
  font-size: 32rpx;
  color: #FFD700;
  margin-bottom: 16rpx;
}

.winner-name {
  font-size: 56rpx;
  font-weight: 700;
  color: #191919;
  margin-bottom: 16rpx;
}

.winner-prize {
  font-size: 28rpx;
  color: #07C160;
  font-weight: 600;
}

.btn-lottery {
  width: 100%;
  height: 88rpx;
  background: #ffffff;
  color: #07C160;
  border: none;
  border-radius: 44rpx;
  font-size: 36rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.btn-lottery:active {
  transform: scale(0.98);
}

.btn-lottery.disabled {
  opacity: 0.6;
}

/* 中奖名单 */
.winners-section {
  margin: 0 32rpx 32rpx;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.winner-count {
  font-size: 24rpx;
  color: #07C160;
  font-weight: 600;
}

.winners-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 24rpx;
}

.winner-card {
  width: calc(50% - 8rpx);
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #F7F7F7;
  border-radius: 12rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.winner-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07C160, #576B95);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-weight: 600;
  font-size: 28rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.winner-info {
  flex: 1;
  min-width: 0;
}

.winner-name {
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.winner-prize {
  font-size: 24rpx;
  color: #07C160;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #CCCCCC;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx 32rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.btn-save {
  flex: 1;
  height: 88rpx;
  background: #07C160;
  color: #ffffff;
  border: none;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.btn-reset {
  flex: 1;
  height: 88rpx;
  background: #ffffff;
  color: #07C160;
  border: 2rpx solid #07C160;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
}

/* 抽奖动画遮罩 */
.lottery-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: overlayIn 0.3s ease;
}

@keyframes overlayIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.overlay-content {
  text-align: center;
  padding: 48rpx;
}

.overlay-rolling {
  color: #ffffff;
}

.rolling-text {
  font-size: 80rpx;
  font-weight: 700;
  animation: rollText 0.15s linear infinite;
}

@keyframes rollText {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.8; transform: scale(0.98); }
}

.rolling-hint {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 24rpx;
}

.overlay-winner {
  animation: winnerReveal 0.5s ease;
}

@keyframes winnerReveal {
  from {
    opacity: 0;
    transform: scale(0.5);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.celebration {
  font-size: 48rpx;
  margin: 16rpx 0;
}

.congrats-text {
  font-size: 36rpx;
  color: #FFD700;
  margin-bottom: 24rpx;
}

.big-winner-name {
  font-size: 96rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 24rpx;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.3);
}

.big-winner-prize {
  font-size: 40rpx;
  color: #FFD700;
  font-weight: 600;
}
